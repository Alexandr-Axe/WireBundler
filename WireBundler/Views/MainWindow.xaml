<Window x:Class="WireBundler.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WireBundler"
        mc:Ignorable="d"
        Title="Wire Bundle Optimiser" Height="650" Width="1000" MinHeight="500" MinWidth="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Wire Bundle Optimiser"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Input"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Button x:Name="LoadFileButton"
                            Content="Load Input File"
                            Width="140"
                            Height="32"
                            Margin="0,0,0,8"
                            Click="LoadFileButton_Click"/>

                    <TextBlock x:Name="SelectedFileTextBlock"
                               Text="No file loaded yet."
                               Foreground="DimGray"
                               Margin="0,0,0,4"/>

                    <TextBlock x:Name="InputStatusTextBlock"
                               Text="Waiting for input."
                               Foreground="DimGray"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="Results"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="WireCountTextBlock"
                               Text="Wire count: -"
                               Margin="0,0,0,4"/>

                    <TextBlock x:Name="BundleDiameterTextBlock"
                               Text="Bundle diameter: -"
                               Margin="0,0,0,4"/>

                    <TextBlock x:Name="ArrangementStatusTextBlock"
                               Text="Arrangement status: waiting for implementation"/>
                    
                    <TextBlock Text="Wire positions:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>

                    <TextBox x:Name="WirePositionsTextBox"
                             Height="140"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <Grid>
                <TextBlock Text="Visualization area"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,8,0,0"/>

                <Canvas x:Name="VisualizationCanvas"
                        Background="#FFF8F8F8"
                        Margin="0,40,0,0"
                        SizeChanged="VisualizationCanvas_SizeChanged"/>
            </Grid>
        </Border>
    </Grid>
</Window>
